{
  "name": "@oricms/astro",
  "version": "1.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./content": {
      "import": "./dist/content.js",
      "types": "./dist/content.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "npm run build && node --test test/*.test.mjs"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "socket.io-client": "^4.8.3",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "astro": "^4.0.0",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "astro": "^4.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
