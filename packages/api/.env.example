# OriCMS Environment Configuration
# Copy this file to .env and fill in your values

# Database
# For Docker Compose: postgresql://oricms:oricms@postgres:5432/oricms
# For local development: postgresql://oricms:oricms@localhost:5432/oricms
DATABASE_URL=postgresql://oricms:oricms@localhost:5432/oricms

# JWT Secret (min 32 characters)
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_ME_WITH_AT_LEAST_32_CHARACTERS

# Encryption Key (32 bytes, 64 hex characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=REPLACE_ME_64_HEX_CHARS_REQUIRED_FOR_DEVELOPMENT_ONLY

# Allow creating sites with file:// repo URLs (development/testing only)
# Keep unset or false in production.
ALLOW_FILE_REPO_URLS=false

# Reverse proxy awareness for request identity.
# Use a trusted hop count such as 1 when the API sits behind a single ingress proxy.
TRUST_PROXY=false

# Production-grade rate limiting requires a shared Redis store so counters survive
# multiple API instances and process restarts.
RATE_LIMIT_REDIS_URL=
RATE_LIMIT_REDIS_PREFIX=oricms:rate-limit
# Optional local-development override. Leave unset in production.
# RATE_LIMIT_STORE=memory

# Optional webhook failure alert routing
# When configured, failed environment deploy/revalidation webhook dispatches
# will be forwarded to Slack and/or PagerDuty.
WEBHOOK_ALERTS_ENABLED=true
WEBHOOK_ALERTS_SLACK_WEBHOOK_URL=
WEBHOOK_ALERTS_PAGERDUTY_ROUTING_KEY=
WEBHOOK_ALERTS_PAGERDUTY_SEVERITY=error
WEBHOOK_ALERTS_SOURCE=oricms-webhooks
