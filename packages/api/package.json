{
  "name": "@ori/api",
  "version": "2.0.0",
  "description": "Ori CMS API - Multi-tenant backend",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "type-check": "tsc --noEmit",
    "typecheck": "npm run type-check",
    "start": "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:verify-migrations": "node scripts/verify-migrations.mjs",
    "db:studio": "prisma studio",
    "lint": "eslint src/**/*.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-cloudfront": "^3.1000.0",
    "@aws-sdk/client-s3": "^3.1000.0",
    "@prisma/client": "^5.22.0",
    "async-mutex": "^0.5.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.0",
    "fast-glob": "^3.3.3",
    "graphql": "^16.13.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^5.1.1",
    "mime-types": "^2.1.35",
    "p-limit": "^7.3.0",
    "redis": "^4.7.1",
    "simple-git": "^3.36.0",
    "socket.io": "^4.8.3",
    "winston": "^3.11.0",
    "yaml": "^2.9.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mime-types": "^2.1.4",
    "@types/node": "^20.10.5",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "loupe": "^2.3.7",
    "prisma": "^5.7.0",
    "supertest": "^7.2.2",
    "tinyspy": "^2.2.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.3.0",
    "vite-node": "^3.2.0",
    "vitest": "^3.2.0"
  }
}
