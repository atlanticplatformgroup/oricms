{
  "name": "@oricms/client",
  "version": "0.1.0",
  "description": "TypeScript client SDK for OriCMS collections APIs",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
